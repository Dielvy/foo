{% extends 'base.html.twig' %}

{% block title %}Admin login
{% endblock %}

{% block body %}
	<div class="container py-5">
		<div class="row justify-content-center mt-5">
			<div class="col-md-5 col-lg-4">

				<div class="card border-0 shadow-lg rounded-4">
					<div class="card-body p-5">

						<div class="text-center mb-4">
							<h1 class="h3 fw-bold">Admin</h1>
							<p class="text-muted">Log in to manage destinations</p>
						</div>

						<form method="post">
							{% if error %}
								<div class="alert alert-danger border-0 small py-2 mb-3">
									<i class="bi bi-exclamation-triangle-fill me-2"></i>
									{{ error.messageKey|trans(error.messageData, 'security') }}
								</div>
							{% endif %}

							<div class="form-floating mb-3">
								<input type="email" value="{{ last_username }}" name="email" id="inputEmail" class="form-control rounded-3" autocomplete="email" placeholder="name@example.com" required autofocus>
								<label for="inputEmail">Email</label>
							</div>

							<div class="form-floating mb-4">
								<input type="password" name="password" id="inputPassword" class="form-control rounded-3" autocomplete="current-password" placeholder="Password" required>
								<label for="inputPassword">Password</label>
							</div>

							<input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

							<div class="d-grid">
								<button class="btn btn-primary btn-lg rounded-pill shadow-sm" type="submit">
									<i class="bi bi-box-arrow-in-right me-2"></i>Log in
								</button>
							</div>

							<div class="text-center mt-4">
								<a href="{{ path('app_destination_index') }}" class="text-decoration-none small text-muted">
									<i class="bi bi-arrow-left"></i>
									Back to the homepage
								</a>
							</div>
						</form>

					</div>
				</div>

				<div class="mt-4 text-center">
					<div class="p-3 bg-light rounded-3 border">
						<small class="text-muted d-block mb-1 font-monospace">Test credentials :</small>
						<code class="small">admin@example.com / password</code>
					</div>
				</div>

			</div>
		</div>
	</div>
{% endblock %}
